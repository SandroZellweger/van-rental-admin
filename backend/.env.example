# VanLife Admin Backend Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=3000

# Frontend Configuration
FRONTEND_URL=http://localhost:8000

# Database Configuration (when implemented)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=vanlife_admin
# DB_USER=vanlife_user
# DB_PASSWORD=your_secure_password

# Redis Configuration (when implemented)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT Configuration (when implemented)
# JWT_SECRET=your_very_secure_jwt_secret_key_here
# JWT_EXPIRY=24h

# Email Configuration (when implemented)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password

# File Upload Configuration
MAX_FILE_SIZE=10mb
UPLOAD_PATH=./uploads

# API Configuration
API_RATE_LIMIT=100
API_RATE_WINDOW=15

# Logging
LOG_LEVEL=info
